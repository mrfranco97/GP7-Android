<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/AuthFragment">

    <fragment
        android:id="@+id/AuthFragment"
        android:name="com.example.xplorenow_android.ui.auth.AuthFragment"
        android:label="Auth"
        tools:layout="@layout/fragment_auth">
        <action
            android:id="@+id/action_AuthFragment_to_OtpFragment"
            app:destination="@id/OtpFragment" />
        <action
            android:id="@+id/action_AuthFragment_to_RegisterFragment"
            app:destination="@id/RegisterFragment" />
        <action
            android:id="@+id/action_AuthFragment_to_ExperienceListFragment"
            app:destination="@id/ExperienceListFragment"
            app:popUpTo="@id/AuthFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/OtpFragment"
        android:name="com.example.xplorenow_android.ui.auth.OtpFragment"
        android:label="Verificar código"
        tools:layout="@layout/fragment_otp">
        <argument
            android:name="email"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <argument
            android:name="otpRequested"
            app:argType="boolean"
            android:defaultValue="false" />
        <action
            android:id="@+id/action_OtpFragment_to_ExperienceListFragment"
            app:destination="@id/ExperienceListFragment"
            app:popUpTo="@id/AuthFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/RegisterFragment"
        android:name="com.example.xplorenow_android.ui.auth.RegisterFragment"
        android:label="Crear cuenta"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_RegisterFragment_to_OtpFragment"
            app:destination="@id/OtpFragment" />
        <action
            android:id="@+id/action_RegisterFragment_to_ExperienceListFragment"
            app:destination="@id/ExperienceListFragment"
            app:popUpTo="@id/AuthFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/ExperienceListFragment"
        android:name="com.example.xplorenow_android.ui.experience.ExperienceListFragment"
        android:label="@string/first_fragment_label"
        tools:layout="@layout/fragment_experience_list">
        <action
            android:id="@+id/action_ExperienceListFragment_to_ProfileFragment"
            app:destination="@id/ProfileFragment" />
        <action
            android:id="@+id/action_ExperienceListFragment_to_ExperienceDetailFragment"
            app:destination="@id/ExperienceDetailFragment" />
        <action
            android:id="@+id/action_ExperienceListFragment_to_MyBookingsFragment"
            app:destination="@id/MyBookingsFragment" />
        <action
            android:id="@+id/action_ExperienceListFragment_to_NewsFragment"
            app:destination="@id/NewsFragment" />
    </fragment>

    <fragment
        android:id="@+id/ProfileFragment"
        android:name="com.example.xplorenow_android.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_ProfileFragment_to_MyBookingsFragment"
            app:destination="@id/MyBookingsFragment" />
        <action
            android:id="@+id/action_ProfileFragment_to_BookingHistoryFragment"
            app:destination="@id/BookingHistoryFragment" />
        <action
            android:id="@+id/action_ProfileFragment_to_AuthFragment"
            app:destination="@id/AuthFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/FavoritesFragment"
        android:name="com.example.xplorenow_android.ui.experience.FavoritesFragment"
        android:label="@string/favorite"
        tools:layout="@layout/fragment_favorites" >
        <action
            android:id="@+id/action_FavoritesFragment_to_ExperienceDetailFragment"
            app:destination="@id/ExperienceDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/ExperienceDetailFragment"
        android:name="com.example.xplorenow_android.ui.experience.ExperienceDetailFragment"
        android:label="ExperienceDetail"
        tools:layout="@layout/fragment_experience_detail">
        <argument
            android:name="experienceId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/MyBookingsFragment"
        android:name="com.example.xplorenow_android.ui.experience.MyBookingsFragment"
        android:label="My Bookings"
        tools:layout="@layout/fragment_my_bookings">
        <action
            android:id="@+id/action_MyBookingsFragment_to_VoucherFragment"
            app:destination="@id/VoucherFragment" />
    </fragment>

    <fragment
        android:id="@+id/BookingHistoryFragment"
        android:name="com.example.xplorenow_android.ui.experience.BookingHistoryFragment"
        android:label="Booking History"
        tools:layout="@layout/fragment_booking_history">
        <action
            android:id="@+id/action_BookingHistoryFragment_to_BookingDetailFragment"
            app:destination="@id/BookingDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/BookingDetailFragment"
        android:name="com.example.xplorenow_android.ui.experience.BookingDetailFragment"
        android:label="Booking Detail"
        tools:layout="@layout/fragment_booking_detail">
        <argument
            android:name="bookingId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/VoucherFragment"
        android:name="com.example.xplorenow_android.ui.experience.VoucherFragment"
        android:label="Voucher"
        tools:layout="@layout/fragment_voucher">
        <argument
            android:name="bookingId"
            app:argType="string" />
        <action
            android:id="@+id/action_VoucherFragment_to_QrScannerFragment"
            app:destination="@id/QrScanFragment" />
    </fragment>


    <fragment
        android:id="@+id/NewsFragment"
        android:name="com.example.xplorenow_android.ui.news.NewsFragment"
        android:label="Noticias"
        tools:layout="@layout/activity_news">
        <action
            android:id="@+id/action_NewsFragment_to_NewsDetailFragment"
            app:destination="@id/NewsDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/QrScanFragment"
        android:name="com.example.xplorenow_android.ui.qr.QrScanFragment"
        android:label="Escanear QR"
        tools:layout="@layout/fragment_qr_scan">
        <action
            android:id="@+id/action_QrScanFragment_to_ExperienceListFragment"
            app:destination="@id/ExperienceListFragment"
            app:popUpTo="@id/ExperienceListFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/NewsDetailFragment"
        android:name="com.example.xplorenow_android.ui.news.NewsDetailFragment"
        android:label="Detalle de noticia"
        tools:layout="@layout/activity_news_detail">
        <action
            android:id="@+id/action_NewsDetailFragment_to_ExperienceDetailFragment"
            app:destination="@id/ExperienceDetailFragment" />
    </fragment>
</navigation>
